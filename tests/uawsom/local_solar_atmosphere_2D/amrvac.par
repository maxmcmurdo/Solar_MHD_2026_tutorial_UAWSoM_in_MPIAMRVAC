!========================================================================================
! Parameter file for 2.5D x-y simulation
!========================================================================================

 &filelist
        base_filename = 'data_test/2_5Dprominence_'
        saveprim      = .true.
        convert   = .false. !we just need .dat files for Jupyter notebook
        convert_type  = 'vtuCCmpi' !ignored by above line
/
        restart_from_file = 'data_test/2_5Dprominence_00last_saved_file.dat' 
	snapshotnext=last_saved_file+1

! if the last file saved was, e.g., 2_5Dprominence_0010.dat,
! then snapshotnext=11, there is no need for 0011.
/

 &savelist
        itsave(1,1) = 0
        itsave(1,2) = 0
        dtsave_log  = 1.0d0 !see updates in 2_5Dprominence_.log file
        dtsave_dat  = 1.0d1 !see updates in /data_test/
/

 &stoplist
        dtmin    = 1.d-6 !safety check that the simulation doesn't grind to a halt
        time_max = 200.0d0 !last snapshot saved
/
	it_max=1
 /
 &methodlist
        time_stepper       = 'threestep'  
        flux_scheme        = 20*'hll'
        limiter            = 20*'vanleer' 
        fix_small_values   = .false.
        check_small_values = .true.
/
! rho m1 m2 m3 e b1 b2 b3 wkpm wApm
&boundlist
       typeboundary_min1 = 'symm','asymm','symm','symm','symm','asymm','symm','symm',2*'symm',2*'symm'
       typeboundary_max1 = 'symm','asymm','symm','symm','symm','asymm','symm','symm',2*'symm',2*'symm'
       typeboundary_min2 = 8*'special',2*'special',2*'special'
       typeboundary_max2 = 8*'special',4*'cont'
/

 &meshlist
        refine_criterion = 0  !want amr? change this from 0 to 3 and refine_max_level to >1
        refine_max_level = 1  !2lvs: 250km x 250 km, 5lvls: 31.25km x 31.25km
        block_nx1        = 10
        block_nx2        = 10
        domain_nx1       = 100
        domain_nx2       = 80
        xprobmin1        = -5.d0
        xprobmax1        = +5.0d0
        xprobmin2        = 0.0d0
        xprobmax2        = 8.0d0
 /

 &paramlist
        typecourant='maxsum'
        courantpar=0.8d0
 /


  &uawsom_list
         uawsom_gravity   = .true.
         uawsom_gamma     = 1.6667d0
         typedivbfix   = 'lindepowel'
         uawsom_thermal_conduction = .true.
         uawsom_radiative_cooling = .true.
         uawsom_trac = .true.
         uawsom_trac_type = 2
         uawsom_energy=.true.
	     uawsom_solve_eaux=.false.
	 	 uawsom_internal_e=.false.
	     uawsom_hydrodynamic_e=.false.
         Busr=10.d0    !in G
         B0field=.true.
  /

 &tc_list
        tc_perpendicular=.false. !generally many orders of magnitude less than parallel
        tc_saturate=.true.
 /

  &rc_list
         ncool = 4000
         coolcurve = 'Colgan_DM'
         coolmethod = 'exact' !don't change!
         tlow       = 4.17d-3
         Tfix       = .true.
  /
